generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== CORE USER ====================

model User {
  id               String  @id @default(cuid())
  name             String
  email            String? @unique
  phone            String? @unique
  password         String
  role             Role    @default(DONOR)
  avatar           String?
  location         String?
  preferredCity    String?
  preferredRadius  Int?    @default(10)
  locationSetByGPS Boolean @default(false)
  isPremium        Boolean @default(false)

  // legacy 0-5 display rating (kept for donor card UI)
  trustRating Float @default(5.0)

  // anti-abuse system
  trustScore             Int       @default(0)
  verificationLevel      Int       @default(0)
  phoneVerified          Boolean   @default(false)
  emailVerified          Boolean   @default(false)
  urgentOverridesUsed    Int       @default(0)
  urgentOverridesResetAt DateTime?

  // layer 2 motherhood verification
  docStatus    DocStatus @default(UNVERIFIED)
  documentUrl  String?
  documentType String?
  documentNote String?
  verifiedAt   DateTime?

  status    UserStatus @default(ACTIVE)
  deletedAt DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // ── cohort / onboarding ──────────────────────────
  onboardingComplete Boolean   @default(false)
  journeyType        String? // "pregnant" | "postpartum" | "donor"
  gender             String    @default("unspecified") // "male" | "female" | "unspecified" — internal only, never shown publicly
  dueDate            DateTime?
  babyBirthDate      DateTime?
  currentStage       String? // stageKey e.g. "pregnancy-4-6"
  countryCode        String? // ISO 3166-1 alpha-2
  countryFlag        String? // flag emoji derived from countryCode
  subTags            String[]  @default([])
  currentCircleId    String? // FK (soft) to Circle — user's active cohort circle (= primaryCircleId)
  graduatedCircleIds String[]  @default([])
  lastStageCheck     DateTime?

  // ── circle identity ──────────────────────────────────────────────────────
  circleIdentitySet       Boolean   @default(false)
  circleContext           String? // "First-time Mom" | "Experienced Mom" | etc. | null = name only
  circleDisplayName       String? // user-chosen display name, max 20 chars
  circleIdentityUpdatedAt DateTime?
  circleIdentitySkippedAt DateTime?

  // ── care bundles ─────────────────────────────────────────────────────────
  lastBundleCompletedAt DateTime?
  activeBundleId        String?

  trustFrozen      Boolean   @default(false)
  trustFrozenUntil DateTime?

  // ── extended trust / impact ──────────────────────────────────────────────
  impactScore              Int       @default(0)
  donorLevel               String    @default("NEW_DONOR")
  bundleRestrictedUntil    DateTime?
  dailyPointsEarned        Int       @default(0)
  dailyPointsDate          DateTime?
  graceRequestsUsed        Int       @default(0)
  activeRequestLockedUntil DateTime?
  requestCountSinceReset   Int       @default(0)
  streakCurrentDays        Int       @default(0)
  streakLastActiveDate     DateTime?
  streakWeeksCompleted     Int       @default(0)
  hasPostedIntro           Boolean   @default(false)

  trustEvents       TrustEvent[]
  trustScoreLogs    TrustScoreLog[]
  trustScoreHistory TrustScoreHistory[]
  impactScoreLogs   ImpactScoreLog[]
  postLikes         PostLike[]
  abuseEventLogs    AbuseEventLog[]
  abuseFlags        AbuseFlag[]

  coordinationMessages CoordinationMessage[]
  coordinationReports  CoordinationReport[]

  // relations
  favourites               Favourite[]
  items                    Item[]
  requests                 Request[]
  sentMessages             Message[]                 @relation("SentMessages")
  conversationParticipants ConversationParticipant[]
  reports                  Report[]                  @relation("ReporterReports")
  reportedItems            Report[]                  @relation("ReportedUserReports")
  reviewsGiven             Review[]                  @relation("ReviewerReviews")
  reviewsReceived          Review[]                  @relation("DonorReviews")
  registers                Register[]                @relation("CreatorRegisters")
  donorAssignments         ItemAssignment[]          @relation("DonorAssignments")
  sentRegisterMessages     RegisterMessage[]         @relation("SentRegisterMessages")

  otpVerifications    OtpVerification[]
  passwordResetTokens PasswordResetToken[]
  categoryCooldowns   CategoryCooldown[]
  urgentOverrides     UrgentOverride[]
  deviceLogs          DeviceLog[]

  circleMembers CircleMember[]
  circlePosts   CirclePost[]
  postReactions PostReaction[]
  postComments  PostComment[]
  postReports   PostReport[]

  bundleInstances     BundleInstance[]      @relation("RecipientBundles")
  bundleContributions BundleContribution[]
  bundleAllocations   BundleAllocation[]
  itemFundings        RegisterItemFunding[]

  totalFundedCents Int @default(0)
  fundingCount     Int @default(0)

  // notification preferences
  notifyNewPosts      Boolean @default(false)
  notifyReplies       Boolean @default(true)
  notifyThreadReplies Boolean @default(true)
  notifyBundleUpdates Boolean @default(true)
  notifyVerification  Boolean @default(true)

  notifications Notification[]
}

// ==================== ITEMS ====================

model Item {
  id           String     @id @default(cuid())
  title        String
  category     String
  condition    String
  quantity     String
  quantityNum  Int        @default(1)
  location     String
  description  String?
  images       String[]
  urgent       Boolean    @default(false)
  status       ItemStatus @default(PENDING)
  adminBlurred Boolean    @default(false)
  frozenAt     DateTime?
  frozenReason String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  donorId    String
  donor      User        @relation(fields: [donorId], references: [id], onDelete: Cascade)
  requests   Request[]
  reports    Report[]    @relation("ReportedItemReports")
  favourites Favourite[]
}

model Favourite {
  id        String   @id @default(cuid())
  userId    String
  itemId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId])
}

model Review {
  id             String   @id @default(cuid())
  pickupRating   Float
  qualityRating  Float
  quantityRating Float
  comment        String?
  createdAt      DateTime @default(now())

  reviewerId String
  reviewer   User    @relation("ReviewerReviews", fields: [reviewerId], references: [id], onDelete: Cascade)
  donorId    String
  donor      User    @relation("DonorReviews", fields: [donorId], references: [id], onDelete: Cascade)
  requestId  String  @unique
  request    Request @relation(fields: [requestId], references: [id], onDelete: Cascade)
}

model Request {
  id        String        @id @default(cuid())
  note      String?
  status    RequestStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  // Review-flow fields
  reasonForRequest String?
  whoIsItFor       String? // ME | MY_BABY
  pickupPreference String? // PICKUP | DELIVERY_SUPPORT
  pickupMode       String? @default("PICKUP") // PICKUP | DELIVERY_SUPPORT
  pickupCategoryId String? // PICKUP_CATEGORIES id e.g. CAFE
  reviewedAt       DateTime?
  reviewNote       String?

  itemId      String
  item        Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  requesterId String
  requester   User   @relation(fields: [requesterId], references: [id], onDelete: Cascade)

  requestNote       String?
  pickupLocationId  String?
  preferredLocation PublicPickupLocation? @relation("RequestPreferredLocation", fields: [pickupLocationId], references: [id])

  conversation Conversation?
  review       Review?
  fulfillment  RequestFulfillment?
  coordination PickupCoordination?
}

model RequestFulfillment {
  id                String            @id @default(cuid())
  requestId         String            @unique
  status            FulfillmentStatus @default(PENDING)
  donorNote         String?
  donorPhotoUrl     String?
  markedAt          DateTime          @default(now())
  recipientResponse String?
  respondedAt       DateTime?
  reminderSentAt    DateTime?
  autoConfirmedAt   DateTime?
  createdAt         DateTime          @default(now())

  request Request @relation(fields: [requestId], references: [id], onDelete: Cascade)
}

enum FulfillmentStatus {
  PENDING
  VERIFIED
  DISPUTED
  AUTO_CONFIRMED
}

model Conversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  requestId    String                    @unique
  request      Request                   @relation(fields: [requestId], references: [id], onDelete: Cascade)
  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  userId         String
  conversationId String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@id([userId, conversationId])
}

model Message {
  id        String   @id @default(cuid())
  text      String
  createdAt DateTime @default(now())

  senderId       String
  sender         User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

// ==================== PICKUP COORDINATION ====================

model PickupCoordination {
  id            String             @id @default(cuid())
  requestId     String             @unique
  locationId    String?
  proposedTime  DateTime?
  proposedBy    String?
  confirmedTime DateTime?
  status        CoordinationStatus @default(PENDING)
  cancelledById String?
  cancelReason  String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  request  Request               @relation(fields: [requestId], references: [id], onDelete: Cascade)
  location PublicPickupLocation? @relation(fields: [locationId], references: [id])
  messages CoordinationMessage[]
  reports  CoordinationReport[]
}

model PublicPickupLocation {
  id        String   @id @default(cuid())
  name      String
  type      String
  address   String   @default("")
  city      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  coordinations     PickupCoordination[]
  preferredRequests Request[]            @relation("RequestPreferredLocation")
}

model CoordinationMessage {
  id             String           @id @default(cuid())
  coordinationId String
  senderId       String
  messageType    CoordMessageType
  content        String?
  createdAt      DateTime         @default(now())

  coordination PickupCoordination @relation(fields: [coordinationId], references: [id], onDelete: Cascade)
  sender       User               @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

model CoordinationReport {
  id             String            @id @default(cuid())
  coordinationId String
  reporterId     String
  reason         CoordReportReason
  notes          String?
  reviewed       Boolean           @default(false)
  createdAt      DateTime          @default(now())

  coordination PickupCoordination @relation(fields: [coordinationId], references: [id], onDelete: Cascade)
  reporter     User               @relation(fields: [reporterId], references: [id], onDelete: Cascade)
}

model Report {
  id        String       @id @default(cuid())
  reason    String
  status    ReportStatus @default(PENDING)
  adminNote String?
  createdAt DateTime     @default(now())

  reporterId   String
  reporter     User    @relation("ReporterReports", fields: [reporterId], references: [id], onDelete: Cascade)
  itemId       String?
  item         Item?   @relation("ReportedItemReports", fields: [itemId], references: [id], onDelete: SetNull)
  targetUserId String?
  targetUser   User?   @relation("ReportedUserReports", fields: [targetUserId], references: [id], onDelete: SetNull)
}

// ==================== REGISTERS ====================

model Register {
  id        String   @id @default(cuid())
  title     String
  city      String
  dueDate   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creatorId String
  creator   User           @relation("CreatorRegisters", fields: [creatorId], references: [id], onDelete: Cascade)
  items     RegisterItem[]
}

model RegisterItem {
  id                 String             @id @default(cuid())
  name               String
  category           String             @default("Other")
  quantity           String             @default("1")
  note               String?
  storeLinks         String[]           @default([])
  status             RegisterItemStatus @default(AVAILABLE)
  catalogItemId      String?
  standardPriceCents Int                @default(0)
  totalFundedCents   Int                @default(0)
  fundingStatus      ItemFundingStatus  @default(UNFUNDED)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  registerId       String
  register         Register              @relation(fields: [registerId], references: [id], onDelete: Cascade)
  catalogItem      ItemCatalog?          @relation(fields: [catalogItemId], references: [id])
  assignment       ItemAssignment?
  funding          RegisterItemFunding[]
  fulfillmentQueue FulfillmentQueue?
}

model ItemAssignment {
  id        String               @id @default(cuid())
  status    ItemAssignmentStatus @default(RESERVED)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  itemId         String            @unique
  item           RegisterItem      @relation(fields: [itemId], references: [id], onDelete: Cascade)
  donorId        String
  donor          User              @relation("DonorAssignments", fields: [donorId], references: [id], onDelete: Cascade)
  messages       RegisterMessage[]
  fulfillmentLog FulfillmentLog?
}

model RegisterMessage {
  id        String   @id @default(cuid())
  text      String
  createdAt DateTime @default(now())

  senderId     String
  sender       User           @relation("SentRegisterMessages", fields: [senderId], references: [id], onDelete: Cascade)
  assignmentId String
  assignment   ItemAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
}

// ==================== TRUST & ANTI-ABUSE ====================

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OtpVerification {
  id        String   @id @default(cuid())
  userId    String
  type      OtpType
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CategoryCooldown {
  id              String   @id @default(cuid())
  userId          String
  category        String
  lastFulfilledAt DateTime
  nextEligibleAt  DateTime
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
}

model FulfillmentLog {
  id               String    @id @default(cuid())
  assignmentId     String    @unique
  donorConfirmed   Boolean   @default(false)
  momConfirmed     Boolean   @default(false)
  mismatch         Boolean   @default(false)
  donorConfirmedAt DateTime?
  momConfirmedAt   DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  assignment ItemAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
}

model UrgentOverride {
  id        String   @id @default(cuid())
  userId    String
  category  String
  reason    String
  month     Int
  year      Int
  reviewed  Boolean  @default(false)
  approved  Boolean  @default(true)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DeviceLog {
  id        String   @id @default(cuid())
  userId    String
  ipAddress String?
  userAgent String?
  action    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==================== ENUMS ====================

enum Role {
  DONOR
  RECIPIENT
  ADMIN
}

enum UserStatus {
  ACTIVE
  PENDING
  FLAGGED
  SUSPENDED
}

enum ItemStatus {
  PENDING
  ACTIVE
  FULFILLED
  REMOVED
  FROZEN
  RESERVED
}

enum RequestStatus {
  PENDING // submitted, waiting donor review
  APPROVED // legacy — treat same as ACCEPTED
  REJECTED // legacy — treat same as DECLINED
  FULFILLED // item handed over
  ACCEPTED // donor accepted, chat opened
  DECLINED // donor declined
  CHAT_OPENED // both in chat
  PICKUP_AGREED // both confirmed pickup time
  CONFIRMED // recipient confirmed receipt
  CANCELLED // either party cancelled
}

enum ReportStatus {
  PENDING
  RESOLVED
  DISMISSED
}

enum RegisterItemStatus {
  AVAILABLE
  RESERVED
  FULFILLED
}

enum ItemAssignmentStatus {
  RESERVED
  PURCHASED
  DELIVERED
}

enum OtpType {
  PHONE
  EMAIL
}

enum DocStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

// ==================== CIRCLES ====================

model Circle {
  id          String   @id @default(cuid())
  name        String
  emoji       String?
  country     String?  @unique // country-based circles
  stageKey    String?  @unique // cohort circles e.g. "pregnancy-4-6"
  groupLetter String? // cohort group letter e.g. "A"
  createdAt   DateTime @default(now())

  members  CircleMember[]
  posts    CirclePost[]
  channels CircleChannel[]
}

model CircleChannel {
  id       String @id @default(cuid())
  circleId String
  name     String
  emoji    String
  order    Int    @default(0)

  circle Circle       @relation(fields: [circleId], references: [id], onDelete: Cascade)
  posts  CirclePost[]
}

model CircleMember {
  userId       String
  circleId     String
  joinedAt     DateTime         @default(now())
  isLeader     Boolean          @default(false)
  lastViewedAt DateTime?
  accessType   CircleAccessType @default(FULL)
  isGraduated  Boolean          @default(false)

  hasSeenWelcome          Boolean @default(false)
  hasSeenModerationBanner Boolean @default(false)
  hasSeenStageTransition  Boolean @default(false)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  circle Circle @relation(fields: [circleId], references: [id], onDelete: Cascade)

  @@id([userId, circleId])
}

model CirclePost {
  id          String       @id @default(cuid())
  circleId    String
  userId      String
  content     String
  category    PostCategory
  photoUrl    String?
  channelId   String?
  isPinned    Boolean      @default(false)
  isHidden    Boolean      @default(false)
  isIntroPost Boolean      @default(false)
  likeCount   Int          @default(0)
  createdAt   DateTime     @default(now())

  circle      Circle         @relation(fields: [circleId], references: [id], onDelete: Cascade)
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel     CircleChannel? @relation(fields: [channelId], references: [id], onDelete: SetNull)
  reactions   PostReaction[]
  comments    PostComment[]
  reports     PostReport[]
  flaggedPost FlaggedPost?
  postLikes   PostLike[]
}

model PostReaction {
  id     String       @id @default(cuid())
  postId String
  userId String
  type   ReactionType

  post CirclePost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model PostComment {
  id            String   @id @default(cuid())
  postId        String
  userId        String
  content       String
  identityLabel String? // computed at creation: "Previously in this stage" | "Mom in [stage]" | null
  createdAt     DateTime @default(now())

  post CirclePost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PostReport {
  id         String   @id @default(cuid())
  postId     String
  reportedBy String
  reason     String
  createdAt  DateTime @default(now())

  post     CirclePost @relation(fields: [postId], references: [id], onDelete: Cascade)
  reporter User       @relation(fields: [reportedBy], references: [id], onDelete: Cascade)

  @@unique([postId, reportedBy])
}

model FlaggedPost {
  id         String     @id @default(cuid())
  postId     String     @unique
  reason     String
  status     FlagStatus @default(PENDING)
  reviewedAt DateTime?
  createdAt  DateTime   @default(now())

  post CirclePost @relation(fields: [postId], references: [id], onDelete: Cascade)
}

enum PostCategory {
  TIP
  STORY
  GRATITUDE
  QUESTION
  SMALL_WIN
  SUPPORT
}

enum ReactionType {
  HEART
  HUG
  CLAP
}

enum FlagStatus {
  PENDING
  APPROVED
  REMOVED
}

enum CircleAccessType {
  FULL
  READ_COMMENT
}

// ==================== CARE BUNDLES ====================

model Campaign {
  id               String         @id @default(cuid())
  title            String
  description      String
  sponsorName      String
  sponsorLogo      String?
  totalBudget      Float
  costPerBundle    Float
  totalBundles     Int
  bundlesRemaining Int
  status           CampaignStatus @default(DRAFT)
  targetStage      String?
  targetRegion     String?
  templateId       String
  startDate        DateTime       @default(now())
  endDate          DateTime?
  createdAt        DateTime       @default(now())

  template  BundleTemplate   @relation(fields: [templateId], references: [id])
  instances BundleInstance[]
}

model BundleTemplate {
  id            String   @id @default(cuid())
  name          String
  description   String
  estimatedCost Float
  items         Json
  targetStage   String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  campaigns Campaign[]
  instances BundleInstance[]
}

model BundleInstance {
  id              String               @id @default(cuid())
  campaignId      String
  templateId      String
  recipientId     String
  status          BundleInstanceStatus @default(REQUESTED)
  requestedAt     DateTime             @default(now())
  approvedAt      DateTime?
  orderedAt       DateTime?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  confirmedAt     DateTime?
  trackingNumber  String?
  orderReference  String?
  deliveryAddress Json
  adminNotes      String?

  campaign  Campaign       @relation(fields: [campaignId], references: [id])
  template  BundleTemplate @relation(fields: [templateId], references: [id])
  recipient User           @relation("RecipientBundles", fields: [recipientId], references: [id], onDelete: Cascade)
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
}

model Notification {
  id                String    @id @default(cuid())
  userId            String
  type              NotifType
  title             String?
  message           String
  isRead            Boolean   @default(false)
  actionLabel       String?
  metadata          Json?
  readAt            DateTime?
  circleId          String?
  postId            String?
  triggeredByUserId String?
  link              String?
  createdAt         DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

enum NotifType {
  // Legacy types (kept for backward compat)
  NEW_POST
  REPLY
  THREAD_REPLY
  RBW_RESTRICTION
  REPORT_CONFIRMED
  FULFILLMENT_PENDING
  FULFILLMENT_CONFIRMED
  FULFILLMENT_REMINDER
  BUNDLE_ALLOCATION_CONFIRM
  ITEM_FULLY_FUNDED
  ITEM_PURCHASED
  ITEM_DISPATCHED
  ITEM_DELIVERED

  // Request flow
  REQUEST_ACCEPTED
  REQUEST_DECLINED
  REQUEST_RECEIVED

  // Item states
  ITEM_RESERVED
  ITEM_FULFILLED
  DELIVERY_CONFIRMED
  FULFILLMENT_DISPUTED

  // Bundle updates
  BUNDLE_UPDATE
  BUNDLE_GOAL_MET
  BUNDLE_DELIVERED

  // Admin & moderation
  ADMIN_MESSAGE
  MODERATION_ACTION
  VERIFICATION_APPROVED
  VERIFICATION_REJECTED
  MANUAL_VERIFIED

  // Circles
  CIRCLE_REPLY
  CIRCLE_THREAD_REPLY
  CIRCLE_NEW_POST
  CIRCLE_MILESTONE

  // Trust & Impact
  TRUST_MILESTONE
  TRUST_WARNING
  DONOR_LEVEL_UP

  // Request lock
  REQUEST_LOCK_CLEARED

  // Coordination
  COORDINATION_ACCEPTED
  COORDINATION_TIME_PROPOSED
  COORDINATION_SCHEDULED
  COORDINATION_CANCELLED
  COORDINATION_DELIVERED
}

enum BundleInstanceStatus {
  AVAILABLE
  REQUESTED
  APPROVED
  ORDERED
  SHIPPED
  DELIVERED
  COMPLETED
  REJECTED
  DISPUTED
}

model TrustEvent {
  id            String   @id @default(cuid())
  userId        String
  eventType     String
  pointsDelta   Int
  reason        String
  referenceId   String?
  referenceType String?
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TrustScoreLog {
  id          String   @id @default(cuid())
  userId      String
  eventType   String
  pointsDelta Int
  newScore    Int
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ImpactScoreLog {
  id          String   @id @default(cuid())
  userId      String
  eventType   String
  pointsDelta Int
  newScore    Int
  referenceId String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post CirclePost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

// ==================== ANTI-ABUSE MONITORING ====================

model AbuseEventLog {
  id         String         @id @default(cuid())
  userId     String
  eventType  AbuseEventType
  timestamp  DateTime       @default(now())
  trustScore Int
  metadata   Json
  ipAddress  String?
  deviceId   String?
  sessionId  String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([eventType])
  @@index([timestamp])
}

model AbuseFlag {
  id         String          @id @default(cuid())
  userId     String
  flagType   AbuseFlagType
  severity   Severity
  status     AbuseFlagStatus @default(OPEN)
  evidence   Json
  createdAt  DateTime        @default(now())
  reviewedAt DateTime?
  reviewedBy String?
  notes      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([severity])
  @@index([createdAt])
}

model TrustScoreHistory {
  id        String   @id @default(cuid())
  userId    String
  oldScore  Int
  newScore  Int
  delta     Int
  reason    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model WeeklyAbuseSummary {
  id                     String   @id @default(cuid())
  weekStart              DateTime
  weekEnd                DateTime
  totalFlags             Int
  highSeverityFlags      Int
  topFlagTypes           Json
  usersDroppedBelow60    Int
  rapidTrustFarmers      Int
  topRequestedCategories Json
  createdAt              DateTime @default(now())
}

enum AbuseEventType {
  SIGNUP
  VERIFICATION_SUBMITTED
  VERIFICATION_APPROVED
  VERIFICATION_REJECTED
  INTRO_POST_CREATED
  CIRCLE_POST_CREATED
  COMMENT_CREATED
  DISCOVER_REQUEST_CREATED
  URGENT_OVERRIDE_USED
  REGISTER_CREATED
  REPORT_SUBMITTED
  TRUST_SCORE_CHANGED
  BUNDLE_REQUESTED
  BUNDLE_APPROVED
  BUNDLE_REJECTED
  FULFILLMENT_MARKED
  FULFILLMENT_DISPUTED
}

enum AbuseFlagType {
  TOO_MANY_REQUESTS_SHORT_WINDOW
  NEW_ACCOUNT_REQUESTING_TOO_FAST
  REPEATED_URGENT_OVERRIDE
  HIGH_REQUEST_LOW_ENGAGEMENT
  SUSPICIOUS_REPORT_VOLUME
  REPEATED_DEVICE_OR_SESSION
  TRUST_SCORE_RECOVERY_SPAM
  REPEATED_BUNDLE_ATTEMPTS
  HIGH_UNVERIFIED_FULFILLMENTS
  DUPLICATE_LISTING
  OFF_PLATFORM_CONTACT
}

enum Severity {
  LOW
  MEDIUM
  HIGH
}

enum AbuseFlagStatus {
  OPEN
  REVIEWED
  CLOSED
  ESCALATED
}

enum CoordinationStatus {
  PENDING
  LOCATION_CONFIRMED
  TIME_PROPOSED
  SCHEDULED
  DONOR_READY
  DELIVERED
  CONFIRMED
  CANCELLED
  REPORTED
}

enum CoordMessageType {
  IM_HERE
  RUNNING_LATE
  ON_MY_WAY
  CANT_MAKE_IT
  PICKUP_COMPLETE
  CUSTOM
}

enum CoordReportReason {
  INAPPROPRIATE_MESSAGES
  REQUESTING_PERSONAL_INFO
  PRESSURE_OR_HARASSMENT
  OFF_PLATFORM_CONTACT_ATTEMPT
  SUSPICIOUS_BEHAVIOUR
  OTHER
}

// ==================== MONTHLY BUNDLE FUNDING ====================

model MonthlyBundleGoal {
  id                 String               @id @default(cuid())
  month              String // "2026-04"
  targetBundles      Int
  costPerBundle      Int // in cents e.g. 4000 = $40
  deliveredBundles   Int                  @default(0)
  bundlesFundedToday Int                  @default(0)
  status             GoalStatus           @default(ACTIVE)
  createdAt          DateTime             @default(now())
  contributions      BundleContribution[]
  allocations        BundleAllocation[]
}

model BundleContribution {
  id          String            @id @default(cuid())
  goalId      String
  donorId     String
  bundleCount Int
  amountCents Int
  paymentRef  String?
  status      PaymentStatus     @default(CONFIRMED)
  createdAt   DateTime          @default(now())
  goal        MonthlyBundleGoal @relation(fields: [goalId], references: [id])
  donor       User              @relation(fields: [donorId], references: [id])
}

model BundleAllocation {
  id              String            @id @default(cuid())
  goalId          String
  recipientId     String
  bundleType      String
  status          AllocationStatus  @default(QUEUED)
  allocatedAt     DateTime          @default(now())
  dispatchedAt    DateTime?
  confirmedAt     DateTime?
  deliveryAddress String?
  notes           String?
  goal            MonthlyBundleGoal @relation(fields: [goalId], references: [id])
  recipient       User              @relation(fields: [recipientId], references: [id])
}

enum GoalStatus {
  ACTIVE
  CLOSED
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  FAILED
}

enum AllocationStatus {
  QUEUED
  APPROVED
  DISPATCHED
  DELIVERED
  CONFIRMED
}

// ==================== HYBRID REGISTER FULFILLMENT ====================

enum FundingStatus {
  PENDING
  CONFIRMED
  REFUNDED
}

enum QueueStatus {
  QUEUED
  PURCHASED
  DISPATCHED
  DELIVERED
}

enum ItemFundingStatus {
  UNFUNDED
  PARTIAL
  FULLY_FUNDED
  IN_FULFILLMENT
  FULFILLED
}

model ItemCatalog {
  id                 String         @id @default(cuid())
  name               String
  category           String
  standardPriceCents Int
  description        String?
  isActive           Boolean        @default(true)
  createdAt          DateTime       @default(now())
  registerItems      RegisterItem[]
}

model RegisterItemFunding {
  id             String        @id @default(cuid())
  registerItemId String
  donorId        String
  amountCents    Int
  status         FundingStatus @default(CONFIRMED)
  createdAt      DateTime      @default(now())

  registerItem RegisterItem @relation(fields: [registerItemId], references: [id], onDelete: Cascade)
  donor        User         @relation(fields: [donorId], references: [id], onDelete: Cascade)
}

model FulfillmentQueue {
  id               String      @id @default(cuid())
  registerItemId   String      @unique
  totalFundedCents Int
  status           QueueStatus @default(QUEUED)
  purchasedFrom    String?
  actualCostCents  Int?
  trackingRef      String?
  notes            String?
  queuedAt         DateTime    @default(now())
  purchasedAt      DateTime?
  dispatchedAt     DateTime?
  deliveredAt      DateTime?

  registerItem RegisterItem @relation(fields: [registerItemId], references: [id], onDelete: Cascade)
}
