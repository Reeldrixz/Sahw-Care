generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== CORE USER ====================

model User {
  id          String     @id @default(cuid())
  name        String
  email       String?    @unique
  phone       String?    @unique
  password    String
  role        Role       @default(DONOR)
  avatar      String?
  location    String?
  isPremium   Boolean    @default(false)

  // legacy 0-5 display rating (kept for donor card UI)
  trustRating Float      @default(5.0)

  // anti-abuse system
  trustScore             Int       @default(50)
  verificationLevel      Int       @default(0)
  phoneVerified          Boolean   @default(false)
  emailVerified          Boolean   @default(false)
  urgentOverridesUsed    Int       @default(0)
  urgentOverridesResetAt DateTime?

  // layer 2 motherhood verification
  docStatus    DocStatus @default(UNVERIFIED)
  documentUrl  String?
  documentType String?
  documentNote String?
  verifiedAt   DateTime?

  status    UserStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // ── cohort / onboarding ──────────────────────────
  onboardingComplete Boolean  @default(false)
  journeyType        String?   // "pregnant" | "postpartum"
  dueDate            DateTime?
  babyBirthDate      DateTime?
  currentStage       String?   // stageKey e.g. "pregnancy-4-6"
  countryCode        String?   // ISO 3166-1 alpha-2
  countryFlag        String?   // flag emoji derived from countryCode
  subTags            String[]  @default([])
  currentCircleId    String?   // FK (soft) to Circle — user's active cohort circle
  graduatedCircleIds String[]  @default([])

  // relations
  items                    Item[]
  requests                 Request[]
  sentMessages             Message[]                 @relation("SentMessages")
  conversationParticipants ConversationParticipant[]
  reports                  Report[]                  @relation("ReporterReports")
  reportedItems            Report[]                  @relation("ReportedUserReports")
  reviewsGiven             Review[]                  @relation("ReviewerReviews")
  reviewsReceived          Review[]                  @relation("DonorReviews")
  registers                Register[]                @relation("CreatorRegisters")
  donorAssignments         ItemAssignment[]          @relation("DonorAssignments")
  sentRegisterMessages     RegisterMessage[]         @relation("SentRegisterMessages")

  otpVerifications  OtpVerification[]
  categoryCooldowns CategoryCooldown[]
  urgentOverrides   UrgentOverride[]
  deviceLogs        DeviceLog[]

  circleMembers CircleMember[]
  circlePosts   CirclePost[]
  postReactions PostReaction[]
  postComments  PostComment[]
  postReports   PostReport[]
}

// ==================== ITEMS ====================

model Item {
  id          String     @id @default(cuid())
  title       String
  category    String
  condition   String
  quantity    String
  location    String
  description String?
  images      String[]
  urgent      Boolean    @default(false)
  status      ItemStatus @default(PENDING)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  donorId  String
  donor    User      @relation(fields: [donorId], references: [id], onDelete: Cascade)
  requests Request[]
  reports  Report[]  @relation("ReportedItemReports")
}

model Review {
  id             String   @id @default(cuid())
  pickupRating   Float
  qualityRating  Float
  quantityRating Float
  comment        String?
  createdAt      DateTime @default(now())

  reviewerId String
  reviewer   User    @relation("ReviewerReviews", fields: [reviewerId], references: [id], onDelete: Cascade)
  donorId    String
  donor      User    @relation("DonorReviews", fields: [donorId], references: [id], onDelete: Cascade)
  requestId  String  @unique
  request    Request @relation(fields: [requestId], references: [id], onDelete: Cascade)
}

model Request {
  id        String        @id @default(cuid())
  note      String?
  status    RequestStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  itemId      String
  item        Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  requesterId String
  requester   User   @relation(fields: [requesterId], references: [id], onDelete: Cascade)

  conversation Conversation?
  review       Review?
}

model Conversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  requestId    String                    @unique
  request      Request                   @relation(fields: [requestId], references: [id], onDelete: Cascade)
  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  userId         String
  conversationId String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@id([userId, conversationId])
}

model Message {
  id        String   @id @default(cuid())
  text      String
  createdAt DateTime @default(now())

  senderId       String
  sender         User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model Report {
  id        String       @id @default(cuid())
  reason    String
  status    ReportStatus @default(PENDING)
  adminNote String?
  createdAt DateTime     @default(now())

  reporterId   String
  reporter     User   @relation("ReporterReports", fields: [reporterId], references: [id], onDelete: Cascade)
  itemId       String?
  item         Item?  @relation("ReportedItemReports", fields: [itemId], references: [id], onDelete: SetNull)
  targetUserId String?
  targetUser   User?  @relation("ReportedUserReports", fields: [targetUserId], references: [id], onDelete: SetNull)
}

// ==================== REGISTERS ====================

model Register {
  id        String   @id @default(cuid())
  title     String
  city      String
  dueDate   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creatorId String
  creator   User           @relation("CreatorRegisters", fields: [creatorId], references: [id], onDelete: Cascade)
  items     RegisterItem[]
}

model RegisterItem {
  id         String             @id @default(cuid())
  name       String
  category   String             @default("Other")
  quantity   String             @default("1")
  note       String?
  storeLinks String[]           @default([])
  status     RegisterItemStatus @default(AVAILABLE)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  registerId String
  register   Register        @relation(fields: [registerId], references: [id], onDelete: Cascade)
  assignment ItemAssignment?
}

model ItemAssignment {
  id        String               @id @default(cuid())
  status    ItemAssignmentStatus @default(RESERVED)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  itemId   String        @unique
  item     RegisterItem  @relation(fields: [itemId], references: [id], onDelete: Cascade)
  donorId  String
  donor    User          @relation("DonorAssignments", fields: [donorId], references: [id], onDelete: Cascade)
  messages RegisterMessage[]
  fulfillmentLog FulfillmentLog?
}

model RegisterMessage {
  id        String   @id @default(cuid())
  text      String
  createdAt DateTime @default(now())

  senderId     String
  sender       User           @relation("SentRegisterMessages", fields: [senderId], references: [id], onDelete: Cascade)
  assignmentId String
  assignment   ItemAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
}

// ==================== TRUST & ANTI-ABUSE ====================

model OtpVerification {
  id        String   @id @default(cuid())
  userId    String
  type      OtpType
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CategoryCooldown {
  id              String   @id @default(cuid())
  userId          String
  category        String
  lastFulfilledAt DateTime
  nextEligibleAt  DateTime
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
}

model FulfillmentLog {
  id               String    @id @default(cuid())
  assignmentId     String    @unique
  donorConfirmed   Boolean   @default(false)
  momConfirmed     Boolean   @default(false)
  mismatch         Boolean   @default(false)
  donorConfirmedAt DateTime?
  momConfirmedAt   DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  assignment ItemAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
}

model UrgentOverride {
  id        String   @id @default(cuid())
  userId    String
  category  String
  reason    String
  month     Int
  year      Int
  reviewed  Boolean  @default(false)
  approved  Boolean  @default(true)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DeviceLog {
  id          String   @id @default(cuid())
  userId      String
  ipAddress   String?
  userAgent   String?
  action      String
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==================== ENUMS ====================

enum Role {
  DONOR
  RECIPIENT
  ADMIN
}

enum UserStatus {
  ACTIVE
  PENDING
  FLAGGED
  SUSPENDED
}

enum ItemStatus {
  PENDING
  ACTIVE
  FULFILLED
  REMOVED
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  FULFILLED
}

enum ReportStatus {
  PENDING
  RESOLVED
  DISMISSED
}

enum RegisterItemStatus {
  AVAILABLE
  RESERVED
  FULFILLED
}

enum ItemAssignmentStatus {
  RESERVED
  PURCHASED
  DELIVERED
}

enum OtpType {
  PHONE
  EMAIL
}

enum DocStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

// ==================== CIRCLES ====================

model Circle {
  id          String   @id @default(cuid())
  name        String
  emoji       String?
  country     String?  @unique   // country-based circles
  stageKey    String?  @unique   // cohort circles e.g. "pregnancy-4-6"
  groupLetter String?            // cohort group letter e.g. "A"
  createdAt   DateTime @default(now())

  members  CircleMember[]
  posts    CirclePost[]
  channels CircleChannel[]
}

model CircleChannel {
  id       String @id @default(cuid())
  circleId String
  name     String
  emoji    String
  order    Int    @default(0)

  circle Circle      @relation(fields: [circleId], references: [id], onDelete: Cascade)
  posts  CirclePost[]
}

model CircleMember {
  userId       String
  circleId     String
  joinedAt     DateTime  @default(now())
  isLeader     Boolean   @default(false)
  lastViewedAt DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  circle Circle @relation(fields: [circleId], references: [id], onDelete: Cascade)

  @@id([userId, circleId])
}

model CirclePost {
  id        String       @id @default(cuid())
  circleId  String
  userId    String
  content   String
  category  PostCategory
  photoUrl  String?
  channelId String?
  isPinned  Boolean      @default(false)
  isHidden  Boolean      @default(false)
  createdAt DateTime     @default(now())

  circle      Circle         @relation(fields: [circleId], references: [id], onDelete: Cascade)
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel     CircleChannel? @relation(fields: [channelId], references: [id], onDelete: SetNull)
  reactions   PostReaction[]
  comments    PostComment[]
  reports     PostReport[]
  flaggedPost FlaggedPost?
}

model PostReaction {
  id     String       @id @default(cuid())
  postId String
  userId String
  type   ReactionType

  post CirclePost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model PostComment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  content   String
  createdAt DateTime @default(now())

  post CirclePost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PostReport {
  id         String   @id @default(cuid())
  postId     String
  reportedBy String
  reason     String
  createdAt  DateTime @default(now())

  post     CirclePost @relation(fields: [postId], references: [id], onDelete: Cascade)
  reporter User       @relation(fields: [reportedBy], references: [id], onDelete: Cascade)

  @@unique([postId, reportedBy])
}

model FlaggedPost {
  id         String     @id @default(cuid())
  postId     String     @unique
  reason     String
  status     FlagStatus @default(PENDING)
  reviewedAt DateTime?
  createdAt  DateTime   @default(now())

  post CirclePost @relation(fields: [postId], references: [id], onDelete: Cascade)
}

enum PostCategory {
  TIP
  STORY
  GRATITUDE
  QUESTION
}

enum ReactionType {
  HEART
  HUG
  CLAP
}

enum FlagStatus {
  PENDING
  APPROVED
  REMOVED
}
